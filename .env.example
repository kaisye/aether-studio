NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
DATABASE_URL=sqlite:///./aether_studio.db
WEB_ORIGIN=http://localhost:3000

# NVIDIA Integrate. Accepts either raw key or "Bearer <key>".
NVIDIA_API_KEY=
NVIDIA_MODEL=qwen/qwen3.5-397b-a17b

# Optional dev/test limits for free or slow API keys.
# Set to a small number like 3 to translate/render only the first subtitle blocks.
AETHER_TRANSLATION_MAX_BLOCKS=
AETHER_TRANSLATION_BATCH_SIZE=20
