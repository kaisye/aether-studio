NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
DATABASE_URL=sqlite:///./aether_studio.db
WEB_ORIGIN=http://localhost:3000

# NVIDIA Integrate. Accepts either raw key or "Bearer <key>".
NVIDIA_API_KEY=
NVIDIA_MODEL=qwen/qwen3.5-397b-a17b

# Optional dev/test limits for free or slow API keys.
# Set to a small number like 3 to translate/render only the first subtitle blocks.
AETHER_TRANSLATION_MAX_BLOCKS=
AETHER_TRANSLATION_BATCH_SIZE=20

# TTS provider.
# edge = local Microsoft Edge TTS fallback.
# omnivoice = call a remote OmniVoice service, usually running on Colab/GPU.
AETHER_TTS_PROVIDER=omnivoice
OMNIVOICE_API_URL=
OMNIVOICE_API_KEY=
OMNIVOICE_MODE=auto
OMNIVOICE_INSTRUCT=
OMNIVOICE_REF_AUDIO_URL=
OMNIVOICE_REF_TEXT=

# Used by the remote OmniVoice service, usually on Colab.
# If these files exist beside omnivoice_service.py, the service uses them by default.
OMNIVOICE_DEFAULT_REF_AUDIO_PATH=omnivoice/Voice_Ref.WAV
OMNIVOICE_DEFAULT_REF_TEXT_PATH=omnivoice/voice_scripts.txt
OMNIVOICE_DEFAULT_INSTRUCTION_PATH=omnivoice/Instruction.txt
