{
  "name": "aether-studio",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "build:web": "npm --workspace apps/web run build",
    "lint:web": "npm --workspace apps/web run lint",
    "dev:api": "python -m uvicorn app.main:app --reload --host 127.0.0.1 --port 8000 --app-dir apps/api",
    "test:api": "pytest apps/api/tests"
  },
  "workspaces": [
    "apps/web"
  ]
}
